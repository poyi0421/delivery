# 資料庫連線設定 (Database Connection Settings)
# 開發環境使用 SQLite，正式環境為 Render PostgreSQL
DATABASE_URL=sqlite:///./delivery.db

# JWT 身份驗證安全設定 (JWT Security Settings)
# 正式環境請更換為強安全密鑰 (可以用 openssl rand -hex 32 產生)
JWT_SECRET=super-secret-key-change-me-in-production-1234567890
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
